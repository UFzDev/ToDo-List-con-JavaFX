<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="900.0" prefWidth="1440.0" styleClass="main-container"
            stylesheets="@../css/global.css,@../css/reports.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ufzdev.todo_list.controllers.ReportsController">

    <left>
        <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
            <VBox styleClass="sidebar-logo-container">
                <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="sidebar-label" text="ToDo List" />
            </VBox>

            <VBox spacing="8.0" styleClass="nav-menu" VBox.vgrow="ALWAYS">
                <Button alignment="BASELINE_LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                        onAction="#handleGoToTasks" styleClass="nav-button" text="Tareas">
                    <graphic>
                        <SVGPath content="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="#64748b" scaleX="0.75" scaleY="0.75" />
                    </graphic>
                </Button>
                <Button alignment="BASELINE_LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                        styleClass="nav-button" text="Estadísticas" onAction="#handleGoToStats">
                    <graphic>
                        <SVGPath content="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.39-.88 4.68-2.63 6.41-3.51 3.48-9.21 3.48-12.72 0s-3.51-9.11 0-12.59c3.51-3.48 9.21-3.48 12.72 0L21 3.12v7z" fill="#64748b" scaleX="0.7" scaleY="0.7" />
                    </graphic>
                </Button>
                <Button fx:id="btnReports" alignment="BASELINE_LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                        styleClass="nav-button, nav-button-active" text="Reportes">
                    <graphic>
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z" fill="#1d4ed8" scaleX="0.7" scaleY="0.7" />
                    </graphic>
                </Button>
            </VBox>

            <VBox styleClass="sidebar-footer">
                <Label styleClass="sidebar-user-label" text="Usuario" />
                <Label fx:id="lblUserName" styleClass="profile-name" text="" />
                <Button maxWidth="1000" onAction="#handleOpenSettings" styleClass="btn-tertiary" text="Editar categorías y estados" />
                <Button maxWidth="1000" onAction="#handleLogout" styleClass="btn-secondary" text="Cerrar sesión" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox fx:id="contentRoot" BorderPane.alignment="CENTER" styleClass="workspace">
            <HBox alignment="BOTTOM_LEFT" spacing="20.0">
                <VBox HBox.hgrow="ALWAYS">
                    <Label styleClass="h1" text="Reportes" />
                    <Label styleClass="subtitle" text="Selecciona los filtros y genera tus archivos." />
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="report-actions">
                    <Button maxWidth="1000.0" mnemonicParsing="false" onAction="#handleCreateExcelReport" styleClass="btn-primary, report-action-button" text="Crear reporte en Excel" />
                    <Button maxWidth="1000.0" mnemonicParsing="false" onAction="#handleCreatePdfReport" styleClass="btn-secondary, report-action-button" text="Crear reporte en PDF" />
                </HBox>
            </HBox>

            <HBox HBox.hgrow="ALWAYS" spacing="20.0" styleClass="report-filter-grid" VBox.vgrow="ALWAYS">
                <VBox HBox.hgrow="ALWAYS" styleClass="report-card">
                    <HBox alignment="CENTER_LEFT" styleClass="report-card-header">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label styleClass="report-card-title" text="Categorías" />
                            <Label styleClass="report-card-subtitle" text="Selecciona una o varias para incluirlas en el reporte." />
                        </VBox>
                    </HBox>

                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefViewportHeight="320.0" styleClass="report-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="categoriesBox" spacing="8.0" styleClass="report-check-list" />
                        </content>
                    </ScrollPane>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" styleClass="report-card">
                    <HBox alignment="CENTER_LEFT" styleClass="report-card-header">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label styleClass="report-card-title" text="Estatus" />
                            <Label styleClass="report-card-subtitle" text="Selecciona uno o varios estados para filtrar el reporte." />
                        </VBox>
                    </HBox>

                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefViewportHeight="320.0" styleClass="report-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="statusesBox" spacing="8.0" styleClass="report-check-list" />
                        </content>
                    </ScrollPane>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" styleClass="report-footer-note">
                <Label styleClass="report-note" text="" />
            </HBox>
        </VBox>
    </center>
</BorderPane>

