<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="ufzdev.todo_list.controllers.LoginController"
      stylesheets="@../css/global.css, @../css/login.css" styleClass="root-main">

    <VBox styleClass="branding-panel" HBox.hgrow="ALWAYS">
        <VBox spacing="40.0" styleClass="branding-content" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="60" bottom="60" left="60" right="60"/>
            </padding>

            <Label text="TO-DO LIST - UFzDev" styleClass="brand-logo"/>

            <VBox spacing="5.0">
                <Label text="Organiza tu día" styleClass="heading-1"/>
                <Label text="Gestiona tareas" styleClass="heading-1"/>
                <Label text="Manten el Control" styleClass="heading-1"/>
                <Label text="Espacio de trabajo para gestionar tareas y proyectos."
                       styleClass="heading-subtitle" wrapText="true"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="60.0" styleClass="stats-container">
                <VBox>
                    <Label text="99%" styleClass="stat-number"/>
                    <Label text="Productividad" styleClass="stat-label"/>
                </VBox>
                <VBox>
                    <Label text="24k+" styleClass="stat-number"/>
                    <Label text="Usuarios" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>

    <VBox styleClass="login-panel" HBox.hgrow="ALWAYS">
        <VBox spacing="30.0" styleClass="login-container">
            <padding>
                <Insets top="40" bottom="40" left="50" right="50"/>
            </padding>

            <VBox spacing="8.0">
                <Label text="Bienvenido" styleClass="form-title"/>
                <Label text="Ingresa tus credenciales para acceder a tu espacio de trabajo."
                       styleClass="form-subtitle" wrapText="true"/>
            </VBox>

            <VBox spacing="20.0">
                <VBox spacing="8.0">
                    <Label text="Correo" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="ejemplo@ejemplo.com" styleClass="input-field"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Contraseña" styleClass="field-label" HBox.hgrow="ALWAYS"/>
                    <PasswordField fx:id="passwordField" promptText="********" styleClass="input-field"/>
                </VBox>
            </VBox>

            <Button fx:id="btnLogin" text="Iniciar Sesión" onAction="#handleLogin" styleClass="btn-login-primary"/>
            <Button fx:id="btnTest" text="Test" onAction="#handleLoginTest" styleClass="btn-test"/>
            <HBox spacing="5.0" alignment="CENTER">
                <Label text="¿No tienes una cuenta?" styleClass="footer-text"/>
                <Label text="Registrate" styleClass="forgot-link" onMouseClicked="#handleOpenRegister"/>
            </HBox>


            <Button fx:id="btnGit" text="Ver proyecto en GitHub" onAction="#handleOpenGithub" styleClass="btn-social" maxWidth="1000"/>
        </VBox>
    </VBox>
</HBox>
