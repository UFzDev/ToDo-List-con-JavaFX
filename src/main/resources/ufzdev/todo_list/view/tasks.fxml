<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="900.0" prefWidth="1440.0" styleClass="main-container"
            stylesheets="@../css/global.css,@../css/tasks.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ufzdev.todo_list.controllers.TasksController">

    <left>
        <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
            <VBox styleClass="sidebar-logo-container">
                <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="sidebar-label" text="ToDo List" />
            </VBox>

            <VBox spacing="8.0" styleClass="nav-menu" VBox.vgrow="ALWAYS">
                <Button alignment="BASELINE_LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                        styleClass="nav-button, nav-button-active" text="Tareas">
                    <graphic>
                        <SVGPath content="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="#1d4ed8" scaleX="0.75" scaleY="0.75" />
                    </graphic>
                </Button>
                <Button alignment="BASELINE_LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                        styleClass="nav-button" text="Estadísticas">
                    <graphic>
                        <SVGPath content="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.39-.88 4.68-2.63 6.41-3.51 3.48-9.21 3.48-12.72 0s-3.51-9.11 0-12.59c3.51-3.48 9.21-3.48 12.72 0L21 3.12v7z" fill="#64748b" scaleX="0.7" scaleY="0.7" />
                    </graphic>
                </Button>
                <Button alignment="BASELINE_LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                        styleClass="nav-button" text="Reportes" onAction="#handleGoToReports">
                    <graphic>
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z" fill="#64748b" scaleX="0.7" scaleY="0.7" />
                    </graphic>
                </Button>
            </VBox>

            <VBox styleClass="sidebar-footer">
                <Label text="Usuario" styleClass="sidebar-user-label"/>
                <Label fx:id="lblUserName" styleClass="profile-name" text="" />
                <Button text="Editar categorías y estados" onAction="#handleOpenSettings" styleClass="btn-tertiary" maxWidth="1000"/>
                <Button text="Cerrar sesión" onAction="#handleLogout" styleClass="btn-secondary" maxWidth="1000"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox BorderPane.alignment="CENTER">
            <VBox styleClass="workspace" VBox.vgrow="ALWAYS">
                <HBox alignment="BOTTOM_LEFT" spacing="20.0">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="h1" text="Espacio de Trabajo Diario" />
                        <Label styleClass="subtitle" text="Gestiona tus tareas y pendientes" />
                    </VBox>
                    <Button text="Editar" onAction="#handleEditTask" styleClass="btn-secondary"/>
                    <Button text="Eliminar" onAction="#handleDeleteTask" styleClass="btn-secondary"/>
                    <Button mnemonicParsing="false" styleClass="btn-primary" text="Nueva Tarea" onAction="#handleNewTask">
                        <graphic>
                            <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" fill="WHITE" scaleX="0.8" scaleY="0.8" />
                        </graphic>
                        <HBox.margin>
                            <Insets bottom="15.0" />
                        </HBox.margin>
                    </Button>
                </HBox>
                <HBox styleClass="bento-filter-section">
                    <HBox styleClass="bento-card" HBox.hgrow="ALWAYS">
                        <SVGPath content="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#737c7f" scaleX="0.8" scaleY="0.8" />
                        <TextField fx:id="txtSearch" promptText="Buscar..." styleClass="bento-input" HBox.hgrow="ALWAYS" onKeyReleased="#handleFilterChanged" />
                    </HBox>
                    <HBox maxWidth="220.0" prefWidth="220.0" styleClass="bento-card">
                        <SVGPath content="M12 2l-5.5 9h11L12 2zm0 3.84L13.93 9h-3.87L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z" fill="#737c7f" scaleX="0.75" scaleY="0.75" />
                        <ComboBox fx:id="cmbCategoryFilter" promptText="Categoría: Todas" styleClass="bento-input" HBox.hgrow="ALWAYS" onAction="#handleFilterChanged" />
                    </HBox>
                    <HBox maxWidth="220.0" prefWidth="220.0" styleClass="bento-card">
                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14h-2v-2h2v2zm0-4h-2V7h2v5z" fill="#737c7f" scaleX="0.75" scaleY="0.75" />
                        <ComboBox fx:id="cmbStatusFilter" promptText="Estado: Todos" styleClass="bento-input" HBox.hgrow="ALWAYS" onAction="#handleFilterChanged" />
                    </HBox>
                </HBox>
                <TableView fx:id="tasksTable" styleClass="tonal-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTaskName" prefWidth="220.0" text="TAREA" />
                        <TableColumn fx:id="colDescription" prefWidth="420.0" text="DESCRIPCIÓN" />
                        <TableColumn fx:id="colCategory" prefWidth="220.0" text="CATEGORÍA" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="ESTADO" />
                        <TableColumn fx:id="colCreatedAt" prefWidth="145.0" text="CREACIÓN" />
                        <TableColumn fx:id="colDueDate" prefWidth="145.0" text="VENCIMIENTO" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
